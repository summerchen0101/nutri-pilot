# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Magic Link：Supabase Dashboard → Authentication → URL Configuration
# Redirect URLs 需包含：http://localhost:3000/auth/callback（與正式站網址）

# Anthropic（Next：`lib/ai/claude.ts`；Edge Function：fetch API）
ANTHROPIC_API_KEY=
# 選填，預設 claude-sonnet-4-20250514
ANTHROPIC_MODEL=

# Upstash QStash（菜單生成、拍照辨識 Worker Queue）
# 僅基底網址，勿含 /v2/publish（錯設會導致 QStash 400 invalid scheme）
# 須與 Upstash Console 顯示的區域一致（例：EU 用 https://qstash-eu-central-1.upstash.io，勿混用全域網址與區域 Token）
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=
# 須含 https://（例：`https://<project-ref>.supabase.co/functions/v1`）；程式會自動補上 scheme
# （Supabase CLI `secrets set` 不可用 SUPABASE_ 開頭變數名，請用 EDGE_FUNCTIONS_URL）
EDGE_FUNCTIONS_URL=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
